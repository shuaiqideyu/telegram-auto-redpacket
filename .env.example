# ===== Telegram 应用凭据（登录新账号用，应用级共享）=====
# 从 https://my.telegram.org 获取；账号在 Web 控制台登录，session 存数据库
API_ID=
API_HASH=

# ===== 数据库（PostgreSQL）=====
# 存账号 session / 系统配置 / 模块开关 / 抢包记录
# 请先手动建库与用户，再填写连接串
DATABASE_URL=postgresql+asyncpg://hongbao:changeme@127.0.0.1:5432/hongbao

# ===== Redis（答案共享 / 去重 / 缓存）=====
REDIS_URL=redis://127.0.0.1:6379/10

# ===== Web 服务 =====
HOST=127.0.0.1
PORT=8000
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# 后端启动时自动恢复所有「已启用+已登录」账号监听（服务器无人值守设 true）
AUTOSTART_ACCOUNTS=false

# ===== 验证码浏览器 =====
# BROWSER_BACKEND: playwright(自带 chromium) | cloak(cloakbrowser 反检测, 需 pip install cloakbrowser)
BROWSER_BACKEND=playwright
HEADLESS=true
# 浏览器可执行文件：本机 macOS 可用系统 Chrome；服务器/Linux 留空用后端自带 chromium
# CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# ===== 以下仅作「首次播种到数据库」的默认值；之后以 Web 控制台(DB) 为准 =====
# 单个红包最多尝试几轮（失败立即重试，抢到/被领完即停）
MAX_ATTEMPTS=4
# 领取状态由 bot 私聊推送给账号本人（登录时账号自动 /start 绑定），避免在群里暴露
NOTIFY_BOT_TOKEN=
# 千问 VL（OpenAI 兼容端点）
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen3-vl-flash
# 多模型并发：'模型:线路名' 逗号分隔，任一识别成功即领取
VISION_MODELS=qwen3-vl-flash:flash,qwen3-vl-plus:plus

# ===== Session 加密（AES-256-GCM）=====
# 留空=明文存储（开发模式）；生产环境填 64 位 hex：
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_ENCRYPT_KEY=
